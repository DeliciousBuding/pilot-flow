{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pilotflow.local/schemas/artifact.schema.json",
  "title": "Artifact",
  "type": "object",
  "required": ["id", "type", "title", "status"],
  "properties": {
    "id": { "type": "string" },
    "type": { "type": "string", "enum": ["doc", "base_record", "task", "message", "card", "run_log", "summary"] },
    "title": { "type": "string" },
    "status": { "type": "string", "enum": ["planned", "created", "failed"] },
    "url": { "type": "string" },
    "external_id": { "type": "string" }
  }
}
