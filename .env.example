PILOTFLOW_LLM_MODEL=
PILOTFLOW_LLM_FALLBACK_MODELS=
PILOTFLOW_LLM_MAX_TOKENS=4096
PILOTFLOW_LLM_TEMPERATURE=0.1

# Optional behavior
PILOTFLOW_SEND_PLAN_CARD=
PILOTFLOW_SEND_ENTRY_MESSAGE=
PILOTFLOW_PIN_ENTRY_MESSAGE=
PILOTFLOW_UPDATE_ANNOUNCEMENT=
PILOTFLOW_SEND_RISK_CARD=
