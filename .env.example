# LLM Configuration (OpenAI-compatible endpoint)
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=your-api-key-here
OPENAI_MODEL=gpt-4.1

# Feishu App Credentials (lark_oapi SDK)
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=your-app-secret
FEISHU_GROUP_POLICY=open

# PilotFlow Configuration
PILOTFLOW_TEST_CHAT_ID=oc_xxxxxxxxxxxxxxxx
PILOTFLOW_MEMORY_ENABLED=true
# Keep false in shared environments. Set true only if member names may be persisted to Hermes memory.
PILOTFLOW_MEMORY_INCLUDE_MEMBERS=false
