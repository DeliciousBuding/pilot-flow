{
  "name": "pilot-flow",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Feishu-native AI project operations officer proof of concept.",
  "scripts": {
    "pilot:check": "node src/interfaces/cli/pilot-cli.js check",
    "pilot:demo": "node src/interfaces/cli/pilot-cli.js demo",
    "pilot:listen": "node src/interfaces/cli/pilot-cli.js listen",
    "pilot:recorder": "node src/interfaces/cli/pilot-cli.js recorder",
    "pilot:status": "node src/interfaces/cli/pilot-cli.js status",
    "pilot:package": "node src/interfaces/cli/pilot-cli.js package",
    "pilot:audit": "node src/interfaces/cli/pilot-cli.js audit",
    "pilot:doctor": "node src/interfaces/cli/pilot-cli.js doctor",
    "pilot:run": "tsc && node dist/src/interfaces/cli/pilot-run.js",
    "pilot:agent-smoke": "tsc && node dist/src/interfaces/cli/agent-smoke.js",
    "pilot:project-init-ts": "tsc && node dist/src/interfaces/cli/agent-project-init.js",
    "check": "node scripts/check-js.js && tsc --noEmit",
    "test": "npm run test:legacy && npm run test:ts",
    "test:legacy": "node scripts/run-tests.js",
    "test:ts": "tsc && node scripts/run-ts-tests.js",
    "test:core": "node scripts/run-tests.js core",
    "test:interfaces": "node scripts/run-tests.js interfaces",
    "test:review": "node scripts/run-tests.js review",
    "test:evals": "node scripts/run-tests.js evals",
    "ts:check": "tsc --noEmit",
    "ts:build": "tsc",
    "pilot:demo:run": "node src/interfaces/cli/manual-trigger.js",
    "pilot:listen:cards": "node src/interfaces/cli/card-listener.js",
    "pilot:recorder:render": "node src/interfaces/cli/flight-recorder-view.js",
    "pilot:doctor:run": "node src/interfaces/cli/doctor.js",
    "pilot:setup": "node src/interfaces/cli/setup-feishu-targets.js",
    "review:evidence": "node src/review-packs/demo-evidence.js",
    "review:eval": "node src/review-packs/demo-eval.js",
    "review:capture": "node src/review-packs/demo-capture-pack.js",
    "review:failure": "node src/review-packs/demo-failure-pack.js",
    "review:readiness": "node src/review-packs/demo-readiness-pack.js",
    "review:permissions": "node src/review-packs/demo-permission-pack.js",
    "review:judge": "node src/review-packs/demo-judge-pack.js",
    "review:callback-verification": "node src/review-packs/demo-callback-verification-pack.js",
    "review:submission": "node src/review-packs/demo-submission-pack.js",
    "review:delivery-index": "node src/review-packs/demo-delivery-index-pack.js",
    "review:safety-audit": "node src/review-packs/demo-safety-audit-pack.js",
    "review:retrospective": "node src/review-packs/run-retrospective-pack.js",
    "review:retrospective-eval": "node src/review-packs/retrospective-eval.js",
    "test:one": "node scripts/run-tests.js"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  }
}
